# =============================================================================
# Copy to .env.local and adjust. NEXT_PUBLIC_* = visible in the browser.
# =============================================================================

# Public URL of this Next.js app (local or production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# STRAPI — CMS (your case: localhost:1330)
# Portfolio: GET {STRAPI}/api/portfolio?populate=deep
# Gallery:   GET {STRAPI}/api/gallery?populate=deep
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRAPI_URL=http://localhost:1330

# -----------------------------------------------------------------------------
# AUTH API — separate service (your case: localhost:3001, routes under /auth)
# Signup/login/logout/me/refresh; uses HTTP-only cookies (withCredentials).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_AUTH_API_BASE_URL=http://localhost:3001/auth
NEXT_PUBLIC_AUTH_SIGNUP_PATH=/signup
NEXT_PUBLIC_AUTH_LOGIN_PATH=/login
NEXT_PUBLIC_AUTH_LOGOUT_PATH=/logout
NEXT_PUBLIC_AUTH_REFRESH_PATH=/refresh
NEXT_PUBLIC_AUTH_ME_PATH=/me

# -----------------------------------------------------------------------------
# CONTACT FORM API — optional second backend (default example port 8000)
# POST {NEXT_PUBLIC_API_BASE_URL}{NEXT_PUBLIC_CONTACT_PATH or /contact}
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
# NEXT_PUBLIC_CONTACT_PATH=/contact

# -----------------------------------------------------------------------------
# AUTH PROXY — server-only; unset locally unless you test the proxy
# Rewrites /api/auth/* → {AUTH_SERVICE_URL}/auth/* (see next.config.mjs)
# Vercel: set AUTH_SERVICE_URL to your auth server and use
# NEXT_PUBLIC_AUTH_API_BASE_URL=/api/auth for same-origin cookies.
# -----------------------------------------------------------------------------
# AUTH_SERVICE_URL=https://your-auth-server.example.com

# Optional server secret (never NEXT_PUBLIC_)
# API_SECRET_KEY=

# -----------------------------------------------------------------------------
# TECH NEWS — optional NewsAPI key for /api/tech-news (Dev.to + Hacker News work keyless)
# -----------------------------------------------------------------------------
# NEWS_API_KEY=

# -----------------------------------------------------------------------------
# ABOUT — Spline 3D scene (public .splinecode URL from Spline editor → Export)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SPLINE_SCENE_URL=https://prod.spline.design/your-id/scene.splinecode

# -----------------------------------------------------------------------------
# PLAYGROUND SHELF — Strapi collection API IDs (see types/playground-shelf.ts)
# playground-tool-games, playground-blogs, playground-snippets, playground-cheatsheets, playground-jobs
# Optional single type: playground-hub (page header only)
# -----------------------------------------------------------------------------
