# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# General backend API  (contact form, etc.)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# ─────────────────────────────────────────────────────────────────────────────
# Strapi CMS  (portfolio content — public read, no token required)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRAPI_URL=http://localhost:1330

# Optional override for the contact endpoint path (default: /contact)
# NEXT_PUBLIC_CONTACT_PATH=/contact

# ─────────────────────────────────────────────────────────────────────────────
# Auth service  (runs on a separate port — tokens stored as HTTP-only cookies)
# Base URL is the root of the auth service; paths are relative to it.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AUTH_API_BASE_URL=http://localhost:3001/auth

# Auth endpoint paths (defaults shown — only set if your service differs)
NEXT_PUBLIC_AUTH_SIGNUP_PATH=/signup
NEXT_PUBLIC_AUTH_LOGIN_PATH=/login
NEXT_PUBLIC_AUTH_LOGOUT_PATH=/logout
NEXT_PUBLIC_AUTH_REFRESH_PATH=/refresh
NEXT_PUBLIC_AUTH_ME_PATH=/me

# ─────────────────────────────────────────────────────────────────────────────
# Auth proxy (server-side only — NOT prefixed with NEXT_PUBLIC_)
# Used by next.config.mjs rewrites to tunnel /api/auth/* → your cloud server.
# On Vercel: add this as a plain environment variable (not NEXT_PUBLIC_).
# When this is set, also point NEXT_PUBLIC_AUTH_API_BASE_URL=/api/auth
# so the browser calls the same-origin proxy instead of the cloud IP directly.
# ─────────────────────────────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://74.220.48.x:3001

# ─────────────────────────────────────────────────────────────────────────────
# Optional: server-side only secret (not exposed to the browser)
# ─────────────────────────────────────────────────────────────────────────────
# API_SECRET_KEY=your-secret-key
